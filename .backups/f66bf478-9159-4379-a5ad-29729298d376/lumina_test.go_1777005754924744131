// TestUserdataMetatable tests the Userdata + Metatable pattern.
// This is the foundation for Component instances in Lumina.
func TestUserdataMetatable(t *testing.T) {
	L := lua.NewState()
	defer L.Close()

	lumina.Open(L)

	// Test 1: Create a Point metatable with __tostring
	// Pattern: NewMetatable -> set methods -> pop
	L.NewMetatable("Point")
	// Set __tostring metamethod
	L.PushFunction(func(L *lua.State) int {
		// Get userdata value (a struct with x, y)
		val := L.UserdataValue(1)
		if pt, ok := val.(struct{ X, Y int }); ok {
			L.PushString("Point(" + itoa(pt.X) + ", " + itoa(pt.Y) + ")")
		} else {
			L.PushString("Point(unknown)")
		}
		return 1
	})
	L.SetField(-2, "__tostring")
	L.Pop(1) // pop the metatable from stack

	// Test 2: Create userdata and attach metatable
	// Create userdata
	L.NewUserdata(0, 0)
	// Set Go value in userdata
	L.SetUserdataValue(-1, struct{ X, Y int }{3, 4})
	// Get metatable from registry and attach
	L.GetField(lua.RegistryIndex, "Point")
	L.SetMetatable(-2)
	// Set as global "p" for Lua access
	L.SetGlobal("p")

	// Test 3: Access from Lua
	err := L.DoString(`
		local s = tostring(p)
		if s ~= "Point(3, 4)" then
			error("expected 'Point(3, 4)', got: " .. s)
		end
		print("Point from Lua: " .. s)
	`)
	if err != nil {
		t.Fatalf("Lua tostring failed: %v", err)
	}

	// Test 4: Verify userdata value is accessible from Go
	L.GetGlobal("p")
	val := L.UserdataValue(-1)
	L.Pop(1)
	if pt, ok := val.(struct{ X, Y int }); ok {
		if pt.X != 3 || pt.Y != 4 {
			t.Fatalf("userdata value corrupted: expected (3, 4), got (%d, %d)", pt.X, pt.Y)
		}
	} else {
		t.Fatalf("userdata value has wrong type: %T", val)
	}
}

// TestComponentMetatable tests the Component-style userdata pattern.
// This demonstrates how Lumina components will work.
func TestComponentMetatable(t *testing.T) {
	L := lua.NewState()
	defer L.Close()

	lumina.Open(L)

	// Define a Component metatable with __index for method delegation
	L.NewMetatable("Component")
	// __index points to itself (method delegation pattern)
	L.PushValue(-1) // copy metatable
	L.SetField(-2, "__index")
	// Add a "render" method
	L.PushFunction(func(L *lua.State) int {
		// self is at index 1 (the userdata)
		L.PushString("rendered content")
		return 1
	})
	L.SetField(-2, "render")
	L.Pop(1) // pop the metatable

	// Create a component userdata with initial state
	L.NewUserdata(0, 0)
	L.SetUserdataValue(-1, map[string]any{
		"name":     "MyComponent",
		"props":    map[string]any{"title": "Hello"},
	})
	L.GetField(lua.RegistryIndex, "Component")
	L.SetMetatable(-2)
	L.SetGlobal("comp")

	// Test 1: Call render() method from Lua (method delegation via __index)
	err := L.DoString(`
		local result = comp:render()
		if result ~= "rendered content" then
			error("expected 'rendered content', got: " .. tostring(result))
		end
		print("render() result: " .. result)
	`)
	if err != nil {
		t.Fatalf("comp:render() failed: %v", err)
	}

	// Test 2: Access properties via Go callback
	L.GetGlobal("comp")            // stack: [comp_userdata]
	L.PushFunction(func(L *lua.State) int {
		val := L.UserdataValue(1)
		if m, ok := val.(map[string]any); ok {
			if name, ok := m["name"].(string); ok {
				L.PushString(name)
				return 1
			}
		}
		L.PushString("")
		return 1
	})
	L.SetField(-2, "getName")      // set on userdata at -2
	L.Pop(1)                       // pop userdata

	err = L.DoString(`
		local name = comp:getName()
		if name ~= "MyComponent" then
			error("expected 'MyComponent', got: " .. name)
		end
		print("component name: " .. name)
	`)
	if err != nil {
		t.Fatalf("comp:getName() failed: %v", err)
	}

	// Test 3: Verify TestUdata for type checking
	L.GetGlobal("comp")
	isComponent := L.TestUdata(-1, "Component")
	L.Pop(1)
	if !isComponent {
		t.Fatal("TestUdata should return true for Component userdata")
	}

	// Test 4: Verify wrong type returns false
	L.GetGlobal("comp")
	isPoint := L.TestUdata(-1, "Point")
	L.Pop(1)
	if isPoint {
		t.Fatal("TestUdata should return false for wrong type")
	}
}

// Helper function for converting int to string
func itoa(i int) string {
	if i < 0 {
		return "-" + itoa(-i)
	}
	if i == 0 {
		return "0"
	}
	s := ""
	for i > 0 {
		s = string(rune('0'+i%10)) + s
		i /= 10
	}
	return s
}