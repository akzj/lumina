package lumina

import (
	"testing"

	"github.com/akzj/go-lua/pkg/lua"
)

// TestRequireLumina verifies that require("lumina") works and exports expected functions.
func TestRequireLumina(t *testing.T) {
	L := lua.NewState()
	defer L.Close()

	// Register lumina package (simulating require("lumina"))
	L.Require("lumina", lua.Function(Open), true)
	L.SetGlobal("lumina")

	// Test: lumina.version() returns version string
	L.GetGlobal("lumina")
	if !L.IsTable(-1) {
		t.Fatal("lumina should be a table")
	}
	L.GetField(-1, "version")
	if !L.IsFunction(-1) {
		t.Fatal("lumina.version should be a function")
	}
	L.Call(0, 1)
	version, ok := L.ToString(-1)
	if !ok || version != "0.1.0" {
		t.Fatalf("expected version 0.1.0, got %s", version)
	}
	L.Pop(1)

	// Test: lumina.create_component(name) returns component string
	L.GetField(-1, "create_component")
	L.PushString("Button")
	L.Call(1, 1)
	result, ok := L.ToString(-1)
	if !ok || result != "component:Button" {
		t.Fatalf("expected component:Button, got %s", result)
	}
	L.Pop(2)

	t.Log("TestRequireLumina passed")
}

// TestSetFuncs verifies that SetFuncs correctly registers multiple functions.
func TestSetFuncs(t *testing.T) {
	L := lua.NewState()
	defer L.Close()

	// Register lumina table with functions
	L.NewTable()
	L.SetFuncs(map[string]lua.Function{
		"fn1": func(L *lua.State) int {
			L.PushInteger(1)
			return 1
		},
		"fn2": func(L *lua.State) int {
			L.PushInteger(2)
			return 1
		},
	}, 0)
	L.SetGlobal("test")

	// Verify both functions exist and work
	L.GetGlobal("test")
	L.GetField(-1, "fn1")
	L.Call(0, 1)
	val, _ := L.ToInteger(-1)
	if val != 1 {
		t.Fatalf("expected fn1() = 1, got %d", val)
	}
	L.Pop(1)

	L.GetField(-1, "fn2")
	L.Call(0, 1)
	val, _ = L.ToInteger(-1)
	if val != 2 {
		t.Fatalf("expected fn2() = 2, got %d", val)
	}
	L.Pop(2)

	t.Log("TestSetFuncs passed")
}

// TestUserdataMetatable verifies Userdata + Metatable pattern works.
func TestUserdataMetatable(t *testing.T) {
	L := lua.NewState()
	defer L.Close()

	// Create metatable for "Component"
	L.NewMetatable("Component")

	// Set __index to the metatable itself (simple inheritance)
	L.PushValue(-1)
	L.SetField(-2, "__index")

	// Set a method on the metatable
	L.PushString("getType")
	L.PushFunction(func(L *lua.State) int {
		L.PushString("Component")
		return 1
	})
	L.SetTable(-3)

	L.Pop(1) // pop metatable

	// Create userdata and set metatable
	L.NewUserdata(0, 0)
	L.SetMetatable(-2)

	// Call method via __index
	L.GetField(-1, "getType")
	L.PushValue(-2) // pass self
	L.Call(1, 1)
	result, ok := L.ToString(-1)
	if !ok || result != "Component" {
		t.Fatalf("expected Component, got %s", result)
	}
	L.Pop(3)

	t.Log("TestUserdataMetatable passed")
}

// TestUpvalueState verifies that upvalue state is preserved across calls.
func TestUpvalueState(t *testing.T) {
	L := lua.NewState()
	defer L.Close()

	// Create a counter closure with an upvalue
	L.PushInteger(0) // initial counter value (upvalue 1)

	counter := func(L *lua.State) int {
		val, _ := L.ToInteger(lua.UpvalueIndex(1))
		val++
		L.PushInteger(val)
		L.Copy(-1, lua.UpvalueIndex(1)) // update the upvalue
		return 1
	}

	L.PushClosure(counter, 1) // 1 upvalue
	L.SetGlobal("counter")

	// First call
	L.GetGlobal("counter")
	L.Call(0, 1)
	val, _ := L.ToInteger(-1)
	if val != 1 {
		t.Fatalf("first call: expected 1, got %d", val)
	}
	L.Pop(1)

	// Second call - state should be preserved
	L.GetGlobal("counter")
	L.Call(0, 1)
	val, _ = L.ToInteger(-1)
	if val != 2 {
		t.Fatalf("second call: expected 2, got %d", val)
	}
	L.Pop(1)

	t.Log("TestUpvalueState passed")
}
